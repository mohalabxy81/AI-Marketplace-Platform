umn":97}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport { LineChart as LineChartIcon, Settings, Shield, Zap, Target } from 'lucide-react';\nimport { AutonomyMetricsService } from '@/features/autonomous/metrics/autonomy-metrics.service';\n\nexport default async function AutonomyMetricsDashboard() {\n  const metrics = await AutonomyMetricsService.getSnapshot();\n\n  return (\n    <div className=\"min-h-screen bg-[#0A0A0F] text-neutral-300 p-8 font-sans\">\n      {/* Header */}\n      <div className=\"mb-8 border-b border-neutral-800 pb-6 flex items-end justify-between\">\n        <div>\n          <div className=\"flex items-center gap-3 mb-2 text-teal-500\">\n            <LineChartIcon className=\"w-6 h-6\" />\n            <h1 className=\"text-sm font-bold uppercase tracking-widest\">Autonomy Metrics</h1>\n          </div>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight\">Enterprise Autonomy Score</h2>\n          <p className=\"text-sm text-neutral-500 mt-2 font-mono\">\n            MATURITY LEVEL: {metrics.maturity_level.replace(/_/g, ' ')} | INDEX: {metrics.autonomous_enterprise_index}/100\n          </p>\n        </div>\n        <div className=\"text-right\">\n          <div className=\"text-3xl font-mono text-teal-500 font-bold border border-teal-900 bg-teal-950/30 px-4 py-2\">\n            {metrics.autonomy_score.value}%\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-12 gap-6\">\n        \n        {/* Core Metrics */}\n        <div className=\"col-span-12 grid grid-cols-4 gap-6\">\n          {[\n            { name: 'Agent Utilization', metric: metrics.agent_utilization },\n            { name: 'Automation Rate', metric: metrics.automation_rate },\n            { name: 'Resolution Rate', metric: metrics.resolution_rate },\n            { name: 'Risk Score', metric: metrics.risk_score }\n          ].map((m, i) => (\n            <div key={i} className=\"border border-neutral-800 bg-[#0c0c12] p-5\">\n              <div className=\"text-xs text-neutral-500 uppercase tracking-widest mb-2\">{m.name}</div>\n              <div className=\"text-2xl font-mono text-white mb-1\">{m.metric.value}{m.metric.unit}</div>\n              <div className=\"flex items-center gap-2\">\n                <div className=\"h-1 flex-1 bg-neutral-900\">\n                  <div \n                    className={`h-full ${m.metric.status === 'ON_TRACK' ? 'bg-teal-500' : m.metric.status === 'AT_RISK' ? 'bg-amber-500' : 'bg-red-500'}`} \n                    style={{ width: `${m.metric.achievement_pct}%` }} \n                  />\n                </div>\n                <span className=\"text-xs font-mono text-neutral-500\">{m.metric.target}{m.metric.unit}</span>\n              </div>\n            </div>\n          ))}\n        </div>\n\n        {/* Decision Breakdown */}\n        <div className=\"col-span-4 border border-neutral-800 bg-[#0c0c12] p-6\">\n          <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-6 flex items-center gap-2\">\n            <Target className=\"w-4 h-4 text-teal-500\" />\n            Decision Routing Today\n          </h3>\n          <div className=\"text-4xl font-mono text-white mb-6 border-b border-neutral-800 pb-4\">\n            {metrics.decision_breakdown.total_decisions_today.toLocaleString()}\n            <span className=\"text-sm text-neutral-500 ml-2\">TOTAL DECISIONS</span>\n          </div>\n          <div className=\"space-y-4 font-mono text-sm\">\n            <div className=\"flex justify-between items-center text-teal-400\">\n              <span>AUTONOMOUS EXEC</span>\n              <span>{metrics.decision_breakdown.autonomous_execution.toLocaleString()}</span>\n            </div>\n            <div className=\"flex justify-between items-center text-teal-500\">\n              <span>AGENT APPROVED</span>\n              <span>{metrics.decision_breakdown.agent_approved.toLocaleString()}</span>\n            </div>\n            <div className=\"flex justify-between items-center text-amber-500\">\n              <span>AI RECOMMENDED</span>\n              <span>{metrics.decision_breakdown.ai_recommended.toLocaleString()}</span>\n            </div>\n            <div className=\"flex justify-between items-center text-red-500\">\n              <span>HUMAN DECISION</span>\n              <span>{metrics.decision_breakdown.human_decision.toLocaleString()}</span>\n            </div>\n            <div className=\"flex justify-between items-center text-neutral-500 border-t border-neutral-800 pt-2 mt-2\">\n              <span>BOARD DECISION</span>\n              <span>{metrics.decision_breakdown.board_decision.toLocaleString()}</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Active Agents */}\n        <div className=\"col-span-8 border border-neutral-800 bg-[#0c0c12] p-6\">\n          <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-6 flex items-center gap-2\">\n            <Zap className=\"w-4 h-4 text-teal-500\" />\n            Agent Fleet Status\n          </h3>\n          <table className=\"w-full text-sm\">\n            <thead className=\"text-xs text-neutral-500 uppercase font-mono border-b border-neutral-800\">\n              <tr>\n                <th className=\"text-left pb-3 font-normal\">Agent</th>\n                <th className=\"text-left pb-3 font-normal\">Status</th>\n                <th className=\"text-right pb-3 font-normal\">Level</th>\n                <th className=\"text-right pb-3 font-normal\">Tasks (Today)</th>\n                <th className=\"text-right pb-3 font-normal\">Success</th>\n              </tr>\n            </thead>\n            <tbody className=\"font-mono\">\n              {metrics.active_agents.map(agent => (\n                <tr key={agent.agent_id} className=\"border-b border-neutral-800/50\">\n                  <td className=\"py-3 text-white\">{agent.name}</td>\n                  <td className=\"py-3\">\n                    <span className={`px-2 py-0.5 text-xs ${agent.status === 'ACTIVE' ? 'bg-teal-900/30 text-teal-400 border border-teal-900' : 'bg-neutral-900 text-neutral-500 border border-neutral-800'}`}>\n                      {agent.status}\n                    </span>\n                  </td>\n                  <td className=\"py-3 text-right text-xs text-neutral-400\">{agent.autonomy_level}</td>\n                  <td className=\"py-3 text-right\">{agent.tasks_today.toLocaleString()}</td>\n                  <td className=\"py-3 text-right text-teal-500\">{(agent.success_rate * 100).toFixed(0)}%</td>\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        </div>\n\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/(super-admin)/autonomous/board/page.tsx","messages":[{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/autonomous/executive/executive-copilot.service' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":3,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":3,"endColumn":101},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":24,"column":11,"nodeType":"JSXOpeningElement","endLine":24,"endColumn":98}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport { Presentation, TrendingUp, ShieldAlert, BarChart3, Clock } from 'lucide-react';\nimport { ExecutiveCopilotService } from '@/features/autonomous/executive/executive-copilot.service';\n\nexport default async function BoardDashboard() {\n  const brief = await ExecutiveCopilotService.generateExecutiveBrief();\n  const kpis = brief.kpi_snapshot.metrics;\n\n  return (\n    <div className=\"min-h-screen bg-white text-neutral-900 p-12 font-sans max-w-7xl mx-auto\">\n      {/* Print-friendly Board Header */}\n      <div className=\"mb-12 border-b-2 border-neutral-900 pb-8 flex items-end justify-between\">\n        <div>\n          <div className=\"flex items-center gap-3 mb-2 text-neutral-500\">\n            <Presentation className=\"w-6 h-6\" />\n            <h1 className=\"text-sm font-bold uppercase tracking-widest\">Board of Directors Reporting</h1>\n          </div>\n          <h2 className=\"text-4xl font-extrabold text-neutral-900 tracking-tight\">Quarterly Performance & Risk Review</h2>\n          <p className=\"text-base text-neutral-500 mt-2 font-mono\">\n            PERIOD: {new Date(brief.period.start).toISOString().split('T')[0]} TO {new Date(brief.period.end).toISOString().split('T')[0]} | GENERATED BY: BOARD COPILOT\n          </p>\n        </div>\n        <div className=\"text-right\">\n          <img src=\"/logo-dark.svg\" alt=\"Company Logo\" className=\"h-12 w-auto mb-4 opacity-10\" />\n          <div className=\"text-sm font-mono text-neutral-500\">CONFIDENTIAL — DO NOT DISTRIBUTE</div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-2 gap-12\">\n        \n        {/* Left Column: Financials & Autonomy */}\n        <div className=\"space-y-12\">\n          \n          <section>\n            <h3 className=\"text-xl font-bold border-b border-neutral-200 pb-2 mb-6 flex items-center gap-2\">\n              <TrendingUp className=\"w-5 h-5\" /> Financial Health\n            </h3>\n            <div className=\"grid grid-cols-2 gap-6\">\n              <div className=\"bg-neutral-50 p-6 border border-neutral-200\">\n                <div className=\"text-sm text-neutral-500 uppercase tracking-widest font-semibold mb-2\">Annual Recurring Revenue</div>\n                <div className=\"text-4xl font-mono font-bold text-neutral-900 mb-2\">${(kpis.arr.value / 1000000).toFixed(2)}M</div>\n                <div className=\"text-sm font-mono text-emerald-600 font-bold\">▲ {kpis.arr.delta_7d} (30D)</div>\n              </div>\n              <div className=\"bg-neutral-50 p-6 border border-neutral-200\">\n                <div className=\"text-sm text-neutral-500 uppercase tracking-widest font-semibold mb-2\">Net Revenue Retention</div>\n                <div className=\"text-4xl font-mono font-bold text-neutral-900 mb-2\">{(kpis.nrr.value * 100).toFixed(1)}%</div>\n                <div className=\"text-sm font-mono text-emerald-600 font-bold\">▲ +{(parseFloat(kpis.nrr.delta_7d)).toFixed(1)}% (30D)</div>\n              </div>\n            </div>\n            <div className=\"mt-6 bg-neutral-50 p-6 border border-neutral-200\">\n              <div className=\"text-sm text-neutral-500 uppercase tracking-widest font-semibold mb-4\">30-Day Forward Projection</div>\n              <div className=\"text-lg text-neutral-800 leading-relaxed\">\n                {brief.revenue_forecast_30d.narrative}\n              </div>\n            </div>\n          </section>\n\n          <section>\n            <h3 className=\"text-xl font-bold border-b border-neutral-200 pb-2 mb-6 flex items-center gap-2\">\n              <BarChart3 className=\"w-5 h-5\" /> Autonomous Operations\n            </h3>\n            <div className=\"bg-neutral-50 p-6 border border-neutral-200\">\n              <div className=\"grid grid-cols-3 gap-4 mb-6\">\n                <div>\n                  <div className=\"text-xs text-neutral-500 uppercase font-semibold\">Autonomy Score</div>\n                  <div className=\"text-2xl font-mono font-bold text-neutral-900\">{(kpis.autonomy_score.value * 100).toFixed(0)}%</div>\n                </div>\n                <div>\n                  <div className=\"text-xs text-neutral-500 uppercase font-semibold\">Resolution Rate</div>\n                  <div className=\"text-2xl font-mono font-bold text-neutral-900\">{(kpis.resolution_rate.value * 100).toFixed(0)}%</div>\n                </div>\n                <div>\n                  <div className=\"text-xs text-neutral-500 uppercase font-semibold\">Revenue Influenced</div>\n                  <div className=\"text-2xl font-mono font-bold text-emerald-600\">+${(brief.autonomy_snapshot.revenue_influenced_usd / 1000).toFixed(0)}K</div>\n                </div>\n              </div>\n              <p className=\"text-sm text-neutral-600\">\n                Platform operations are increasingly handled by autonomous agents. {brief.autonomy_snapshot.autonomous_decisions_today.toLocaleString()} decisions were executed autonomously today, saving an estimated ${(brief.autonomy_snapshot.cost_saved_usd / 1000).toFixed(1)}K in operational costs MTD.\n              </p>\n            </div>\n          </section>\n\n        </div>\n\n        {/* Right Column: Risks & Strategy */}\n        <div className=\"space-y-12\">\n          \n          <section>\n            <h3 className=\"text-xl font-bold border-b border-neutral-200 pb-2 mb-6 flex items-center gap-2 text-red-600\">\n              <ShieldAlert className=\"w-5 h-5\" /> Key Risks & Mitigations\n            </h3>\n            <div className=\"space-y-6\">\n              {brief.risks.map((risk, idx) => (\n                <div key={idx} className=\"bg-white border-l-4 border-red-500 p-5 shadow-sm border border-neutral-200\">\n                  <div className=\"flex justify-between items-start mb-2\">\n                    <h4 className=\"text-base font-bold text-neutral-900\">{risk.description.split('—')[0]}</h4>\n                    <span className=\"bg-red-100 text-red-700 text-xs font-bold px-2 py-1 uppercase rounded-sm\">\n                      IMPACT: {risk.impact_score}/5\n                    </span>\n                  </div>\n                  <p className=\"text-sm text-neutral-600 mb-3\">{risk.description.split('—')[1] || risk.description}</p>\n                  <div className=\"bg-neutral-50 p-3 text-sm\">\n                    <span className=\"font-semibold text-neutral-700\">Mitigation:</span> {risk.mitigation}\n                  </div>\n                </div>\n              ))}\n            </div>\n          </section>\n\n          <section>\n            <h3 className=\"text-xl font-bold border-b border-neutral-200 pb-2 mb-6 flex items-center gap-2\">\n              <Clock className=\"w-5 h-5\" /> Strategic Recommendations\n            </h3>\n            <div className=\"space-y-6\">\n              {brief.recommendations.map((rec, idx) => (\n                <div key={idx} className=\"bg-neutral-50 border border-neutral-200 p-5\">\n                  <h4 className=\"text-base font-bold text-neutral-900 mb-2\">{rec.title}</h4>\n                  <p className=\"text-sm text-neutral-600 mb-4\">{rec.description}</p>\n                  <div className=\"flex gap-4 text-xs font-mono text-neutral-500 uppercase\">\n                    <span>OWNER: <strong className=\"text-neutral-900\">{rec.suggested_owner}</strong></span>\n                    <span>IMPACT: <strong className=\"text-emerald-600\">+${(rec.expected_impact_usd! / 1000).toFixed(0)}K</strong></span>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </section>\n\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/(super-admin)/autonomous/executive/page.tsx","messages":[{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/autonomous/executive/executive-copilot.service' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":3,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":3,"endColumn":101}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport { BrainCircuit, TrendingUp, AlertTriangle, CheckCircle, Activity, Zap, DollarSign } from 'lucide-react';\nimport { ExecutiveCopilotService } from '@/features/autonomous/executive/executive-copilot.service';\n\nexport default async function ExecutiveCopilotDashboard() {\n  const brief = await ExecutiveCopilotService.generateExecutiveBrief();\n  const kpis = brief.kpi_snapshot.metrics;\n\n  return (\n    <div className=\"min-h-screen bg-[#0A0A0F] text-neutral-300 p-8 font-sans\">\n      {/* Header */}\n      <div className=\"mb-8 border-b border-neutral-800 pb-6 flex items-end justify-between\">\n        <div>\n          <div className=\"flex items-center gap-3 mb-2 text-amber-500\">\n            <BrainCircuit className=\"w-6 h-6\" />\n            <h1 className=\"text-sm font-bold uppercase tracking-widest\">Executive Intelligence Layer</h1>\n          </div>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight\">CEO Copilot Console</h2>\n          <p className=\"text-sm text-neutral-500 mt-2 font-mono\">\n            PERIOD: {new Date(brief.period.start).toISOString().split('T')[0]} TO {new Date(brief.period.end).toISOString().split('T')[0]} | ID: {brief.brief_id}\n          </p>\n        </div>\n        <div className=\"text-right\">\n          <div className=\"text-xs uppercase tracking-widest text-neutral-500 mb-1\">Platform Status</div>\n          <div className=\"flex items-center gap-2\">\n            <div className=\"w-2 h-2 rounded-none bg-emerald-500 animate-pulse\" />\n            <span className=\"font-mono text-emerald-500 font-bold\">NOMINAL</span>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-12 gap-6\">\n        \n        {/* KPI Panel - 8 cols */}\n        <div className=\"col-span-8 space-y-6\">\n          <div className=\"border border-neutral-800 bg-[#0c0c12] p-6 relative\">\n            <div className=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-amber-500 to-teal-500\" />\n            <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-6\">Real-Time Telemetry</h3>\n            \n            <div className=\"grid grid-cols-4 gap-6\">\n              {[\n                { name: 'ARR', val: kpis.arr, icon: DollarSign },\n                { name: 'NRR', val: kpis.nrr, icon: TrendingUp },\n                { name: 'Autonomy', val: kpis.autonomy_score, icon: Zap },\n                { name: 'Trust', val: kpis.trust_score_avg, icon: CheckCircle }\n              ].map((k, i) => (\n                <div key={i} className=\"border border-neutral-800 p-4 bg-black\">\n                  <div className=\"flex items-center justify-between mb-4\">\n                    <span className=\"text-xs text-neutral-500 uppercase\">{k.name}</span>\n                    <k.icon className=\"w-4 h-4 text-neutral-600\" />\n                  </div>\n                  <div className=\"text-2xl font-mono text-white mb-2\">\n                    {k.name === 'ARR' ? '$' + (k.val.value / 1000000).toFixed(2) + 'M' : \n                     k.name === 'NRR' || k.name === 'Autonomy' || k.name === 'Trust' ? (k.val.value * 100).toFixed(1) + (k.name === 'Trust' ? '' : '%') : \n                     k.val.value.toLocaleString()}\n                  </div>\n                  <div className={`text-xs font-mono font-bold flex items-center gap-1 ${k.val.status === 'ON_TRACK' ? 'text-teal-500' : k.val.status === 'AT_RISK' ? 'text-amber-500' : 'text-red-500'}`}>\n                    {k.val.trend === 'UP' ? '▲' : k.val.trend === 'DOWN' || k.val.trend === 'DOWN_GOOD' ? '▼' : '▬'} {k.val.delta_7d}\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n\n          {/* AI Insights */}\n          <div className=\"border border-neutral-800 bg-[#0c0c12] p-6\">\n            <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-6 flex items-center gap-2\">\n              <Activity className=\"w-4 h-4 text-amber-500\" />\n              Intelligence Synthesis\n            </h3>\n            <div className=\"space-y-4\">\n              {brief.ai_insights.map(insight => (\n                <div key={insight.id} className=\"border-l-2 border-neutral-700 pl-4 py-1\">\n                  <div className=\"flex items-center gap-2 mb-1\">\n                    <span className={`text-xs font-mono px-2 py-0.5 bg-neutral-900 ${insight.impact === 'POSITIVE' ? 'text-teal-500' : 'text-red-500'}`}>\n                      {insight.category}\n                    </span>\n                    <span className=\"text-xs text-neutral-500 font-mono\">CONFIDENCE: {(insight.confidence * 100).toFixed(0)}%</span>\n                  </div>\n                  <h4 className=\"text-white font-bold mb-1\">{insight.headline}</h4>\n                  <p className=\"text-sm text-neutral-400\">{insight.detail}</p>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n\n        {/* Action Panel - 4 cols */}\n        <div className=\"col-span-4 space-y-6\">\n          {/* Revenue Forecast */}\n          <div className=\"border border-neutral-800 bg-[#0c0c12] p-6\">\n            <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-4\">30-Day Forecast</h3>\n            <div className=\"text-3xl font-mono text-white mb-1\">\n              ${(brief.revenue_forecast_30d.forecast_mrr / 1000).toFixed(1)}K\n            </div>\n            <div className=\"text-xs text-neutral-500 font-mono mb-4\">\n              MRR PROJECTION | CI: ±{((brief.revenue_forecast_30d.confidence_interval.upper / brief.revenue_forecast_30d.forecast_mrr - 1) * 100).toFixed(1)}%\n            </div>\n            <p className=\"text-sm text-neutral-400 border-t border-neutral-800 pt-4\">\n              {brief.revenue_forecast_30d.narrative}\n            </p>\n          </div>\n\n          {/* Recommendations */}\n          <div className=\"border border-neutral-800 bg-[#0c0c12] p-6\">\n            <h3 className=\"text-xs font-bold text-amber-500 uppercase tracking-widest mb-4\">Awaiting Decision</h3>\n            <div className=\"space-y-4\">\n              {brief.recommendations.map(rec => (\n                <div key={rec.id} className=\"bg-black border border-neutral-800 p-4\">\n                  <div className=\"flex justify-between items-start mb-2\">\n                    <h4 className=\"text-sm font-bold text-white\">{rec.title}</h4>\n                    {rec.urgency === 'HIGH' && <AlertTriangle className=\"w-4 h-4 text-amber-500\" />}\n                  </div>\n                  <p className=\"text-xs text-neutral-400 mb-4\">{rec.description}</p>\n                  <div className=\"flex justify-between items-center\">\n                    <span className=\"text-xs font-mono text-teal-500\">+${(rec.expected_impact_usd! / 1000).toFixed(1)}K ARR</span>\n                    <button className=\"bg-neutral-800 hover:bg-neutral-700 text-white text-xs px-3 py-1 font-mono uppercase transition-colors\">\n                      Approve\n                    </button>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/(super-admin)/autonomous/revenue/page.tsx","messages":[{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/autonomous/revenue/revenue-agent.service' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":3,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":3,"endColumn":91},{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/autonomous/revenue/retention-agent.service' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":4,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":4,"endColumn":95}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport { CreditCard, DollarSign, TrendingUp, AlertCircle, ArrowUpRight, ShieldCheck } from 'lucide-react';\nimport { RevenueAgentService } from '@/features/autonomous/revenue/revenue-agent.service';\nimport { RetentionAgentService } from '@/features/autonomous/revenue/retention-agent.service';\n\nexport default async function RevenueAgentsDashboard() {\n  const [opportunities, attribution, metrics] = await Promise.all([\n    RevenueAgentService.scanRevenueOpportunities(),\n    RevenueAgentService.getRevenueAttribution({ start: '2026-05-01', end: '2026-05-31' }),\n    RetentionAgentService.getRetentionMetrics()\n  ]);\n\n  const totalOpportunityValue = opportunities.reduce((sum, opp) => sum + opp.expected_impact_usd, 0);\n\n  return (\n    <div className=\"min-h-screen bg-[#0A0A0F] text-neutral-300 p-8 font-sans\">\n      {/* Header */}\n      <div className=\"mb-8 border-b border-neutral-800 pb-6 flex items-end justify-between\">\n        <div>\n          <div className=\"flex items-center gap-3 mb-2 text-emerald-500\">\n            <CreditCard className=\"w-6 h-6\" />\n            <h1 className=\"text-sm font-bold uppercase tracking-widest\">Revenue Autonomy Layer</h1>\n          </div>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight\">Revenue Agents Console</h2>\n        </div>\n        <div className=\"text-right\">\n          <div className=\"text-xs uppercase tracking-widest text-neutral-500 mb-1\">Attributed Revenue (MTD)</div>\n          <div className=\"text-3xl font-mono text-emerald-500 font-bold border border-emerald-900 bg-emerald-950/30 px-4 py-2\">\n            +${(attribution.total_revenue_influenced_usd / 1000).toFixed(1)}K\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-12 gap-6\">\n        \n        {/* Retention Engine */}\n        <div className=\"col-span-4 space-y-6\">\n          <div className=\"border border-neutral-800 bg-[#0c0c12] p-6\">\n            <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-4 flex items-center gap-2\">\n              <ShieldCheck className=\"w-4 h-4 text-emerald-500\" />\n              Retention Engine\n            </h3>\n            <div className=\"grid grid-cols-2 gap-4 mb-6\">\n              <div className=\"border border-neutral-800 bg-black p-4\">\n                <div className=\"text-xs text-neutral-500 uppercase\">Save Rate</div>\n                <div className=\"text-xl font-mono text-white\">{(metrics.save_rate * 100).toFixed(1)}%</div>\n              </div>\n              <div className=\"border border-neutral-800 bg-black p-4\">\n                <div className=\"text-xs text-neutral-500 uppercase\">Saved ARR</div>\n                <div className=\"text-xl font-mono text-emerald-500\">${(metrics.revenue_saved_usd / 1000).toFixed(1)}K</div>\n              </div>\n            </div>\n            <div className=\"text-xs text-neutral-400 font-mono border-t border-neutral-800 pt-4\">\n              <span className=\"text-emerald-500\">{(metrics.agent_attribution_pct * 100).toFixed(0)}%</span> OF SAVES FULLY AUTONOMOUS\n            </div>\n          </div>\n\n          <div className=\"border border-neutral-800 bg-[#0c0c12] p-6\">\n            <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-4 flex items-center gap-2\">\n              <DollarSign className=\"w-4 h-4 text-emerald-500\" />\n              Agent ROI\n            </h3>\n            <div className=\"space-y-3 font-mono text-sm\">\n              {Object.entries(attribution.roi_per_agent).map(([agent, roi]) => (\n                <div key={agent} className=\"flex justify-between items-center border-b border-neutral-800/50 pb-2\">\n                  <span className=\"text-neutral-400 text-xs\">{agent.replace(' Agent', '')}</span>\n                  <span className=\"text-emerald-500\">{roi.toFixed(1)}x</span>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n\n        {/* Live Opportunities */}\n        <div className=\"col-span-8 border border-neutral-800 bg-[#0c0c12] p-6\">\n          <div className=\"flex justify-between items-center mb-6\">\n            <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest flex items-center gap-2\">\n              <TrendingUp className=\"w-4 h-4 text-emerald-500\" />\n              Live Revenue Interventions\n            </h3>\n            <div className=\"text-xs font-mono text-emerald-500 bg-emerald-950/30 px-2 py-1 border border-emerald-900\">\n              PIPELINE: ${(totalOpportunityValue / 1000).toFixed(1)}K\n            </div>\n          </div>\n\n          <div className=\"space-y-4\">\n            {opportunities.map(opp => (\n              <div key={opp.opportunity_id} className=\"border border-neutral-800 bg-black p-4\">\n                <div className=\"flex justify-between items-start mb-3\">\n                  <div className=\"flex items-center gap-3\">\n                    <span className={`px-2 py-0.5 text-[10px] font-mono border ${\n                      opp.urgency === 'CRITICAL' ? 'bg-red-950/30 text-red-500 border-red-900' :\n                      opp.urgency === 'HIGH' ? 'bg-amber-950/30 text-amber-500 border-amber-900' :\n                      'bg-emerald-950/30 text-emerald-500 border-emerald-900'\n                    }`}>\n                      {opp.type}\n                    </span>\n                    <span className=\"text-sm font-bold text-white\">{opp.tenant_name}</span>\n                  </div>\n                  <div className=\"text-right\">\n                    <div className=\"text-sm font-mono text-emerald-500\">+${(opp.expected_impact_usd / 1000).toFixed(1)}K</div>\n                    <div className=\"text-[10px] text-neutral-500 font-mono\">CONF: {(opp.confidence * 100).toFixed(0)}%</div>\n                  </div>\n                </div>\n                \n                <p className=\"text-sm text-neutral-400 mb-4\">{opp.recommended_action}</p>\n                \n                <div className=\"flex justify-between items-center pt-3 border-t border-neutral-800\">\n                  <div className=\"text-[10px] text-neutral-500 font-mono uppercase\">\n                    SOURCE: {opp.agent_source} | POLICY: {opp.autonomy_level}\n                  </div>\n                  {opp.autonomy_level === 'AI_RECOMMENDED' ? (\n                    <button className=\"flex items-center gap-1 bg-emerald-900/30 hover:bg-emerald-900/50 text-emerald-500 border border-emerald-900 text-xs px-3 py-1 font-mono uppercase transition-colors\">\n                      <AlertCircle className=\"w-3 h-3\" /> Approve\n                    </button>\n                  ) : (\n                    <div className=\"flex items-center gap-1 text-[10px] text-neutral-500 font-mono\">\n                      <ArrowUpRight className=\"w-3 h-3\" /> AUTO-QUEUED\n                    </div>\n                  )}\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/(super-admin)/autonomous/risk/page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'RefreshCw' is defined but never used.","line":2,"column":47,"nodeType":"Identifier","messageId":"unusedVar","endLine":2,"endColumn":56,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"RefreshCw"},"fix":{"range":[71,82],"text":""},"desc":"Remove unused variable \"RefreshCw\"."}]},{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/autonomous/executive/risk-forecast.service' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":3,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":3,"endColumn":93}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React from 'react';\nimport { ShieldAlert, Activity, AlertOctagon, RefreshCw, BarChart2 } from 'lucide-react';\nimport { RiskForecastService } from '@/features/autonomous/executive/risk-forecast.service';\n\nexport default async function RiskForecastDashboard() {\n  const register = await RiskForecastService.getRiskRegister();\n\n  return (\n    <div className=\"min-h-screen bg-[#0A0A0F] text-neutral-300 p-8 font-sans\">\n      {/* Header */}\n      <div className=\"mb-8 border-b border-neutral-800 pb-6 flex items-end justify-between\">\n        <div>\n          <div className=\"flex items-center gap-3 mb-2 text-red-500\">\n            <ShieldAlert className=\"w-6 h-6\" />\n            <h1 className=\"text-sm font-bold uppercase tracking-widest\">Risk Autonomy Layer</h1>\n          </div>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight\">Enterprise Risk Forecast</h2>\n        </div>\n        <div className=\"text-right\">\n          <div className=\"text-xs uppercase tracking-widest text-neutral-500 mb-1\">Composite Risk Score</div>\n          <div className={`text-3xl font-mono font-bold border px-4 py-2 ${\n            register.risk_level === 'CRITICAL' ? 'text-red-500 border-red-900 bg-red-950/30' :\n            register.risk_level === 'HIGH' ? 'text-amber-500 border-amber-900 bg-amber-950/30' :\n            register.risk_level === 'MEDIUM' ? 'text-yellow-500 border-yellow-900 bg-yellow-950/30' :\n            'text-emerald-500 border-emerald-900 bg-emerald-950/30'\n          }`}>\n            {register.overall_risk_score.toFixed(3)} <span className=\"text-sm font-sans tracking-widest ml-1\">{register.risk_level}</span>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-12 gap-6\">\n        \n        {/* Monte Carlo Sim */}\n        <div className=\"col-span-12 border border-neutral-800 bg-[#0c0c12] p-6\">\n          <div className=\"flex justify-between items-start mb-6\">\n            <div>\n              <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest flex items-center gap-2 mb-1\">\n                <Activity className=\"w-4 h-4 text-red-500\" />\n                Monte Carlo Simulation (10,000 Iterations)\n              </h3>\n              <p className=\"text-sm text-neutral-500\">Probabilistic financial impact over 90-day horizon</p>\n            </div>\n            <div className=\"text-right\">\n              <div className=\"text-xs text-neutral-500 uppercase font-mono mb-1\">P(Impact &gt; $500K)</div>\n              <div className=\"text-xl font-mono text-amber-500\">{(register.monte_carlo_summary.probability_of_major_impact * 100).toFixed(1)}%</div>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-3 gap-6\">\n            <div className=\"bg-black border border-neutral-800 p-4\">\n              <div className=\"text-[10px] text-neutral-500 uppercase tracking-widest mb-1\">P50 (Median Case)</div>\n              <div className=\"text-2xl font-mono text-emerald-500\">${(register.monte_carlo_summary.p50_impact_usd / 1000).toFixed(1)}K</div>\n            </div>\n            <div className=\"bg-black border border-neutral-800 p-4\">\n              <div className=\"text-[10px] text-neutral-500 uppercase tracking-widest mb-1\">P90 (Worst Case 10%)</div>\n              <div className=\"text-2xl font-mono text-amber-500\">${(register.monte_carlo_summary.p90_impact_usd / 1000).toFixed(1)}K</div>\n            </div>\n            <div className=\"bg-black border border-neutral-800 p-4\">\n              <div className=\"text-[10px] text-neutral-500 uppercase tracking-widest mb-1\">P99 (Tail Risk 1%)</div>\n              <div className=\"text-2xl font-mono text-red-500\">${(register.monte_carlo_summary.p99_impact_usd / 1000).toFixed(1)}K</div>\n            </div>\n          </div>\n        </div>\n\n        {/* Risk Registry */}\n        <div className=\"col-span-8 border border-neutral-800 bg-[#0c0c12] p-6\">\n          <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-6 flex items-center gap-2\">\n            <AlertOctagon className=\"w-4 h-4 text-red-500\" />\n            Active Risk Registry\n          </h3>\n\n          <div className=\"space-y-4\">\n            {register.risks.map(risk => (\n              <div key={risk.risk_id} className=\"border border-neutral-800 bg-black p-4\">\n                <div className=\"flex justify-between items-start mb-3\">\n                  <div>\n                    <div className=\"flex items-center gap-3 mb-1\">\n                      <span className={`px-2 py-0.5 text-[10px] font-mono border ${\n                        risk.severity === 'CRITICAL' ? 'bg-red-950/30 text-red-500 border-red-900' :\n                        risk.severity === 'HIGH' ? 'bg-amber-950/30 text-amber-500 border-amber-900' :\n                        'bg-yellow-950/30 text-yellow-500 border-yellow-900'\n                      }`}>\n                        {risk.category}\n                      </span>\n                      <span className=\"text-[10px] text-neutral-500 font-mono\">ID: {risk.risk_id}</span>\n                    </div>\n                    <h4 className=\"text-base font-bold text-white\">{risk.name}</h4>\n                  </div>\n                  <div className=\"text-right\">\n                    <div className=\"text-sm font-mono text-red-500\">SCORE: {risk.composite_score.toFixed(3)}</div>\n                    <div className=\"text-[10px] text-neutral-500 font-mono uppercase mt-1\">\n                      {risk.trend === 'DETERIORATING' ? '▲ WORSENING' : risk.trend === 'IMPROVING' ? '▼ IMPROVING' : '▬ STABLE'}\n                    </div>\n                  </div>\n                </div>\n                \n                <p className=\"text-sm text-neutral-400 mb-4\">{risk.description}</p>\n                \n                <div className=\"bg-neutral-900/50 p-3 border-l-2 border-amber-500 mb-4\">\n                  <div className=\"text-[10px] text-amber-500 font-mono uppercase mb-1\">Mitigation Strategy</div>\n                  <div className=\"text-sm text-neutral-300\">{risk.mitigation}</div>\n                </div>\n\n                <div className=\"flex justify-between items-center text-[10px] text-neutral-500 font-mono uppercase border-t border-neutral-800 pt-3\">\n                  <div>OWNER: <span className=\"text-neutral-300\">{risk.owner}</span></div>\n                  <div>PROB: {(risk.probability * 100).toFixed(0)}% | HORIZON: {risk.time_horizon}</div>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Concentration Risks */}\n        <div className=\"col-span-4 space-y-6\">\n          <div className=\"border border-neutral-800 bg-[#0c0c12] p-6\">\n            <h3 className=\"text-xs font-bold text-neutral-500 uppercase tracking-widest mb-6 flex items-center gap-2\">\n              <BarChart2 className=\"w-4 h-4 text-amber-500\" />\n              Concentration Exposure\n            </h3>\n            <div className=\"space-y-5\">\n              {register.concentration_risks.map((cr, i) => (\n                <div key={i}>\n                  <div className=\"flex justify-between items-center mb-1\">\n                    <span className=\"text-xs text-neutral-300 uppercase\">{cr.type}</span>\n                    <span className={`text-xs font-mono ${cr.at_risk ? 'text-red-500' : 'text-teal-500'}`}>\n                      {cr.concentration_pct}% (Limit: {cr.threshold_pct}%)\n                    </span>\n                  </div>\n                  <p className=\"text-[10px] text-neutral-500 mb-2\">{cr.description}</p>\n                  <div className=\"h-1 w-full bg-neutral-900\">\n                    <div \n                      className={`h-full ${cr.at_risk ? 'bg-red-500' : 'bg-teal-500'}`} \n                      style={{ width: `${Math.min(cr.concentration_pct, 100)}%` }} \n                    />\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/(super-admin)/billing/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/(super-admin)/dashboard/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/(super-admin)/layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/(super-admin)/tenants/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/api/platform/ai/config/route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/api/platform/moderation/queue/route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/api/platform/snapshot/route.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/api/webhooks/stripe/route.ts","messages":[{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/billing/services/subscription.service' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":2,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":2,"endColumn":88},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":25,"column":17,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":25,"endColumn":20,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[729,732],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[729,732],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":58,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":58,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1904,1907],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1904,1907],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { NextResponse } from \"next/server\";\nimport { subscriptionService } from \"@/features/billing/services/subscription.service\";\n\n// Mock stripe instance for architectural purposes\nconst stripeMock = {\n  webhooks: {\n    constructEvent: (body: string, sig: string | null, secret: string | undefined) => {\n      if (!sig || !secret) throw new Error(\"Missing stripe signature or secret\");\n      return JSON.parse(body);\n    }\n  }\n};\n\nexport async function POST(req: Request) {\n  const body = await req.text();\n  const signature = req.headers.get(\"Stripe-Signature\");\n\n  let event;\n  try {\n    event = stripeMock.webhooks.constructEvent(\n      body,\n      signature,\n      process.env.STRIPE_WEBHOOK_SECRET\n    );\n  } catch (err: any) {\n    console.error(`[Webhook] Signature verification failed:`, err.message);\n    return new NextResponse(`Webhook Error: ${err.message}`, { status: 400 });\n  }\n\n  try {\n    switch (event.type) {\n      case \"customer.subscription.created\":\n      case \"customer.subscription.updated\":\n      case \"customer.subscription.deleted\": {\n        const subscription = event.data.object;\n        \n        const stripeCustomerId = subscription.customer as string;\n        const stripeSubId = subscription.id as string;\n        // Map stripe price ID to internal plan ID\n        const planId = mapStripePriceToPlanId(subscription.items.data[0].price.id);\n        const status = subscription.status;\n        const currentPeriodEnd = new Date(subscription.current_period_end * 1000);\n\n        await subscriptionService.handleSubscriptionUpsert(\n          stripeCustomerId,\n          stripeSubId,\n          planId,\n          status,\n          currentPeriodEnd\n        );\n        break;\n      }\n      default:\n        console.log(`[Webhook] Unhandled event type ${event.type}`);\n    }\n\n    return new NextResponse(JSON.stringify({ received: true }), { status: 200 });\n  } catch (error: any) {\n    console.error(`[Webhook] Handler failed:`, error.message);\n    return new NextResponse(`Webhook Handler Error: ${error.message}`, { status: 500 });\n  }\n}\n\n// Mock mapping\nfunction mapStripePriceToPlanId(priceId: string): string {\n  const map: Record<string, string> = {\n    \"price_free\": \"plan_free\",\n    \"price_growth\": \"plan_growth\",\n    \"price_scale\": \"plan_scale\",\n    \"price_enterprise\": \"plan_enterprise\"\n  };\n  return map[priceId] || \"plan_free\";\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/error.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/global-error.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/layout.tsx","messages":[{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/branding/components/theme-provider' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":5,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":5,"endColumn":79}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import type { Metadata } from \"next\";\nimport { Geist, Geist_Mono } from \"next/font/google\";\nimport { QueryProvider } from \"@/components/providers/query-provider\";\nimport { AuthProvider } from \"@/components/providers/auth-provider\";\nimport { ThemeProvider } from \"@/features/branding/components/theme-provider\";\nimport { Toaster } from \"sonner\";\nimport \"./globals.css\";\n\nconst geistSans = Geist({\n  variable: \"--font-geist-sans\",\n  subsets: [\"latin\"],\n});\n\nconst geistMono = Geist_Mono({\n  variable: \"--font-geist-mono\",\n  subsets: [\"latin\"],\n});\n\nexport const metadata: Metadata = {\n  title: \"Company Dashboard\",\n  description: \"Company management dashboard\",\n  openGraph: {\n    title: \"Company Dashboard\",\n    description: \"Company management dashboard\",\n    type: \"website\",\n  },\n};\n\nexport default function RootLayout({\n  children,\n}: Readonly<{\n  children: React.ReactNode;\n}>) {\n  return (\n    <html\n      lang=\"en\"\n      suppressHydrationWarning\n      className={`${geistSans.variable} ${geistMono.variable} h-full antialiased`}\n    >\n      <body suppressHydrationWarning className=\"min-h-full flex flex-col bg-[var(--color-bg)] text-[var(--color-text)] selection:bg-[var(--color-accent)] selection:text-black\">\n        <QueryProvider>\n          <AuthProvider>\n            <ThemeProvider>\n              {children}\n              <Toaster position=\"top-right\" richColors />\n            </ThemeProvider>\n          </AuthProvider>\n        </QueryProvider>\n      </body>\n    </html>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/super-admin/ai-control/page.tsx","messages":[{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/platform-core/hooks/use-admin-auth' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":5,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":5,"endColumn":78},{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/ai/hooks/use-ai-config' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":6,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":6,"endColumn":171},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Cpu' is defined but never used.","line":8,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":6,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Cpu"},"fix":{"range":[349,353],"text":""},"desc":"Remove unused variable \"Cpu\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Check' is defined but never used.","line":8,"column":23,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":28,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Check"},"fix":{"range":[367,374],"text":""},"desc":"Remove unused variable \"Check\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'HelpCircle' is defined but never used.","line":9,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":13,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"HelpCircle"},"fix":{"range":[389,404],"text":""},"desc":"Remove unused variable \"HelpCircle\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'BarChart2' is defined but never used.","line":9,"column":25,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":34,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"BarChart2"},"fix":{"range":[414,425],"text":""},"desc":"Remove unused variable \"BarChart2\"."}]},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/mohal665544/pr1/company-dashboard/app/super-admin/ai-control/page.tsx:30:7\n  28 |   React.useEffect(() => {\n  29 |     if (config) {\n> 30 |       setModelName(config.active_model_name);\n     |       ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  31 |       setSemanticWeight(Number(config.semantic_weight));\n  32 |       setKeywordWeight(Number(config.keyword_weight));\n  33 |       setBm25Weight(Number(config.bm25_weight));","line":30,"column":7,"nodeType":null,"endLine":30,"endColumn":19}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// app/(super-admin)/ai-control/page.tsx\n\"use client\";\n\nimport * as React from \"react\";\nimport { useAdminAuth } from \"@/features/platform-core/hooks/use-admin-auth\";\nimport { useAIConfigQuery, useAIExperimentsQuery, useAIInferenceLogsQuery, useUpdateWeightsMutation, useTriggerReindexMutation } from \"@/features/ai/hooks/use-ai-config\";\nimport { \n  Cpu, Sliders, Play, Check, AlertTriangle, \n  HelpCircle, Sparkles, BarChart2, Activity, Terminal\n} from \"lucide-react\";\nimport { toast } from \"sonner\";\n\nexport default function AIControlPage() {\n  const { hasCapability, admin } = useAdminAuth();\n  const { data: config } = useAIConfigQuery();\n  const { data: experiments } = useAIExperimentsQuery();\n  const { data: inferenceLogs } = useAIInferenceLogsQuery();\n\n  const updateConfigMutation = useUpdateWeightsMutation();\n  const triggerReindexMutation = useTriggerReindexMutation();\n\n  // Local state for weights\n  const [modelName, setModelName] = React.useState(\"\");\n  const [semanticWeight, setSemanticWeight] = React.useState(0.5);\n  const [keywordWeight, setKeywordWeight] = React.useState(0.3);\n  const [bm25Weight, setBm25Weight] = React.useState(0.2);\n\n  React.useEffect(() => {\n    if (config) {\n      setModelName(config.active_model_name);\n      setSemanticWeight(Number(config.semantic_weight));\n      setKeywordWeight(Number(config.keyword_weight));\n      setBm25Weight(Number(config.bm25_weight));\n    }\n  }, [config]);\n\n  if (!hasCapability(\"configure_ml_weights\")) {\n    return (\n      <div className=\"flex h-[60vh] flex-col items-center justify-center border border-dashed border-red-500/40 bg-zinc-950 p-8 text-center font-mono text-xs\">\n        <AlertTriangle className=\"mb-4 h-8 w-8 text-red-500 animate-pulse\" />\n        <span className=\"text-red-500 font-bold uppercase tracking-wider\">ERROR: ACCESS_DENIED</span>\n        <p className=\"mt-2 text-zinc-400\">\n          Required Capability: <code className=\"bg-zinc-900 px-2 py-1 text-amber-500\">configure_ml_weights</code> is missing.\n        </p>\n      </div>\n    );\n  }\n\n  const handleWeightChange = (type: \"semantic\" | \"keyword\" | \"bm25\", val: number) => {\n    if (type === \"semantic\") {\n      setSemanticWeight(val);\n    } else if (type === \"keyword\") {\n      setKeywordWeight(val);\n    } else if (type === \"bm25\") {\n      setBm25Weight(val);\n    }\n  };\n\n  const totalWeights = Number((semanticWeight + keywordWeight + bm25Weight).toFixed(2));\n  const isWeightValid = Math.abs(totalWeights - 1.0) < 0.001;\n\n  const handleDeployConfig = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!isWeightValid) {\n      toast.error(`Invalid weights: Sum must be exactly 1.00 (Current sum: ${totalWeights})`);\n      return;\n    }\n    if (!config) return;\n\n    updateConfigMutation.mutate({\n      adminId: admin?.id || \"unknown_admin\",\n      semanticWeight,\n      keywordWeight,\n      bm25Weight\n    });\n  };\n\n  return (\n    <div className=\"space-y-6 font-mono text-xs\">\n      {/* Title Header */}\n      <div className=\"flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between border border-zinc-800 bg-zinc-950 p-4\">\n        <div className=\"space-y-1\">\n          <h2 className=\"text-sm font-bold text-zinc-100 uppercase tracking-widest\">AI_GOVERNANCE_CONTROL</h2>\n          <p className=\"text-[10px] text-zinc-500\">Hyperparameter weight distribution and model experimentation plane</p>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 gap-6 lg:grid-cols-3\">\n        {/* LEFT COLUMN: Weight Slider Form */}\n        <div className=\"border border-zinc-800 bg-zinc-950 p-4 space-y-4 lg:col-span-2\">\n          <div className=\"flex items-center space-x-2 border-b border-zinc-800 pb-2\">\n            <Sliders className=\"h-4 w-4 text-amber-500\" />\n            <span className=\"font-bold text-zinc-200 uppercase\">Search Tuning Weights</span>\n          </div>\n\n          <form onSubmit={handleDeployConfig} className=\"space-y-6\">\n            <div>\n              <label className=\"block text-[10px] font-bold text-zinc-500 uppercase mb-1\">Active Index Model</label>\n              <input \n                type=\"text\" \n                value={modelName}\n                onChange={(e) => setModelName(e.target.value)}\n                className=\"w-full border border-zinc-800 bg-zinc-900 px-3 py-1.5 text-zinc-200 outline-none focus:border-amber-500\"\n              />\n            </div>\n\n            <div className=\"space-y-4\">\n              {/* Semantic Weight Slider */}\n              <div className=\"space-y-1.5\">\n                <div className=\"flex justify-between\">\n                  <span className=\"font-bold text-zinc-300\">SEMANTIC_SEARCH_WEIGHT</span>\n                  <span className=\"text-amber-500 font-bold\">{(semanticWeight * 100).toFixed(0)}%</span>\n                </div>\n                <input \n                  type=\"range\"\n                  min=\"0\"\n                  max=\"1\"\n                  step=\"0.05\"\n                  value={semanticWeight}\n                  onChange={(e) => handleWeightChange(\"semantic\", parseFloat(e.target.value))}\n                  className=\"w-full accent-amber-500 h-1 bg-zinc-800 rounded-none cursor-pointer\"\n                />\n              </div>\n\n              {/* Keyword Weight Slider */}\n              <div className=\"space-y-1.5\">\n                <div className=\"flex justify-between\">\n                  <span className=\"font-bold text-zinc-300\">KEYWORD_EXACT_MATCH</span>\n                  <span className=\"text-amber-500 font-bold\">{(keywordWeight * 100).toFixed(0)}%</span>\n                </div>\n                <input \n                  type=\"range\"\n                  min=\"0\"\n                  max=\"1\"\n                  step=\"0.05\"\n                  value={keywordWeight}\n                  onChange={(e) => handleWeightChange(\"keyword\", parseFloat(e.target.value))}\n                  className=\"w-full accent-amber-500 h-1 bg-zinc-800 rounded-none cursor-pointer\"\n                />\n              </div>\n\n              {/* BM25 Weight Slider */}\n              <div className=\"space-y-1.5\">\n                <div className=\"flex justify-between\">\n                  <span className=\"font-bold text-zinc-300\">BM25_LEXICAL_RANKING</span>\n                  <span className=\"text-amber-500 font-bold\">{(bm25Weight * 100).toFixed(0)}%</span>\n                </div>\n                <input \n                  type=\"range\"\n                  min=\"0\"\n                  max=\"1\"\n                  step=\"0.05\"\n                  value={bm25Weight}\n                  onChange={(e) => handleWeightChange(\"bm25\", parseFloat(e.target.value))}\n                  className=\"w-full accent-amber-500 h-1 bg-zinc-800 rounded-none cursor-pointer\"\n                />\n              </div>\n            </div>\n\n            {/* Sum validation indicator */}\n            <div className={`border p-3 text-[10px] font-bold flex items-center justify-between uppercase ${\n              isWeightValid ? \"border-emerald-500/20 bg-emerald-950/10 text-emerald-500\" : \"border-red-500/20 bg-red-950/10 text-red-500\"\n            }`}>\n              <span>TOTAL_WEIGHTS_ACCUMULATION: {totalWeights.toFixed(2)} / 1.00</span>\n              <span>{isWeightValid ? \"VALID\" : \"INVALID_SUMMATION\"}</span>\n            </div>\n\n            <button \n              type=\"submit\"\n              disabled={updateConfigMutation.isPending || !isWeightValid}\n              className=\"w-full flex items-center justify-center space-x-1 border border-amber-500 bg-amber-500/10 py-2 text-amber-500 hover:bg-amber-500 hover:text-black font-bold transition-colors disabled:opacity-50\"\n            >\n              <Sparkles className=\"h-4 w-4\" />\n              <span>DEPLOY_HYPERPARAMETERS</span>\n            </button>\n          </form>\n        </div>\n\n        {/* RIGHT COLUMN: Pipeline and A/B Experiments */}\n        <div className=\"space-y-6\">\n          {/* Embedding pipeline status */}\n          <div className=\"border border-zinc-800 bg-zinc-950 p-4 space-y-4\">\n            <div className=\"flex items-center space-x-2 border-b border-zinc-800 pb-2\">\n              <Activity className=\"h-4 w-4 text-emerald-500\" />\n              <span className=\"font-bold text-zinc-200 uppercase\">Embedding Pipeline</span>\n            </div>\n            \n            <div className=\"space-y-2\">\n              <div className=\"flex justify-between\">\n                <span className=\"text-zinc-500\">Pipeline Status</span>\n                <span className=\"text-emerald-400 font-bold\">STABLE</span>\n              </div>\n              <div className=\"flex justify-between\">\n                <span className=\"text-zinc-500\">Stale Embeddings</span>\n                <span className=\"text-amber-500 font-bold\">14 listings</span>\n              </div>\n              <div className=\"flex justify-between\">\n                <span className=\"text-zinc-500\">Total Indexed</span>\n                <span className=\"text-zinc-300 font-bold\">12,408 vectors</span>\n              </div>\n\n              <button \n                onClick={() => triggerReindexMutation.mutate({})}\n                disabled={triggerReindexMutation.isPending}\n                className=\"w-full mt-2 flex items-center justify-center space-x-1 border border-zinc-700 bg-zinc-900 py-1.5 text-zinc-300 hover:border-zinc-500 hover:text-white disabled:opacity-50 transition-colors\"\n              >\n                <Play className=\"h-3.5 w-3.5 text-emerald-500\" />\n                <span>FORCE_PIPELINE_REBUILD</span>\n              </button>\n            </div>\n          </div>\n\n          {/* Inference Latency log */}\n          <div className=\"border border-zinc-800 bg-zinc-950 p-4 space-y-4\">\n            <div className=\"flex items-center space-x-2 border-b border-zinc-800 pb-2\">\n              <Terminal className=\"h-4 w-4 text-zinc-400\" />\n              <span className=\"font-bold text-zinc-200 uppercase\">Inference Telemetry Feed</span>\n            </div>\n\n            <div className=\"space-y-2 max-h-[160px] overflow-y-auto custom-scrollbar\">\n              {inferenceLogs?.slice(0, 5).map((log) => (\n                <div key={log.id} className=\"border-l border-zinc-800 pl-2 text-[10px] space-y-0.5\">\n                  <div className=\"flex justify-between\">\n                    <span className=\"font-bold text-zinc-300\">{log.model_name.slice(0, 15)}...</span>\n                    <span className={log.status_code === 200 ? \"text-emerald-500\" : \"text-red-500\"}>\n                      {log.latency_ms}ms\n                    </span>\n                  </div>\n                  <div className=\"text-zinc-500 text-[9px]\">\n                    Tokens: {log.tokens_used} | Code: {log.status_code}\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* A/B Experiments Block */}\n      <div className=\"border border-zinc-800 bg-zinc-950 p-4\">\n        <div className=\"flex items-center justify-between border-b border-zinc-800 pb-2 mb-3\">\n          <span className=\"font-bold text-[10px] text-zinc-400 uppercase\">ACTIVE_MODEL_EXPERIMENTS</span>\n          <span className=\"text-[9px] text-zinc-500 font-bold uppercase\">A/B GATEWAY ROUTING</span>\n        </div>\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full text-left border-collapse\">\n            <thead>\n              <tr className=\"border-b border-zinc-800 text-zinc-500 uppercase text-[9px] bg-zinc-900/30\">\n                <th className=\"p-3 font-bold\">Experiment Name</th>\n                <th className=\"p-3 font-bold\">Model A (Control)</th>\n                <th className=\"p-3 font-bold\">Model B (Candidate)</th>\n                <th className=\"p-3 font-bold\">Traffic Split</th>\n                <th className=\"p-3 font-bold\">Status</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-zinc-850\">\n              {experiments && experiments.length > 0 ? (\n                experiments.map((exp) => (\n                  <tr key={exp.id} className=\"hover:bg-zinc-900/40 transition-colors\">\n                    <td className=\"p-3\">\n                      <div className=\"font-bold text-zinc-200\">{exp.name}</div>\n                      <div className=\"text-[9px] text-zinc-500\">{exp.description}</div>\n                    </td>\n                    <td className=\"p-3 text-zinc-400\">{exp.model_a}</td>\n                    <td className=\"p-3 text-zinc-400\">{exp.model_b}</td>\n                    <td className=\"p-3 font-bold text-amber-500\">{exp.split_percentage}% / {100 - exp.split_percentage}%</td>\n                    <td className=\"p-3\">\n                      <span className={`inline-flex px-2 py-0.5 text-[9px] font-bold uppercase ${\n                        exp.status === \"ACTIVE\" \n                          ? \"bg-emerald-950/40 text-emerald-500 border border-emerald-500/20\" \n                          : \"bg-zinc-900 text-zinc-500 border border-zinc-800\"\n                      }`}>\n                        {exp.status}\n                      </span>\n                    </td>\n                  </tr>\n                ))\n              ) : (\n                <tr>\n                  <td colSpan={5} className=\"p-8 text-center text-zinc-600 font-bold\">\n                    NO_EXPERIMENTS_LAUNCHED\n                  </td>\n                </tr>\n              )}\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/super-admin/analytics/page.tsx","messages":[{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/platform-core/hooks/use-admin-auth' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":5,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":5,"endColumn":78},{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/analytics/hooks/use-analytics-data' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":6,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":6,"endColumn":92},{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/ai/hooks/use-ai-config' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":7,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":7,"endColumn":77},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'BarChart3' is defined but never used.","line":9,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":12,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"BarChart3"},"fix":{"range":[346,356],"text":""},"desc":"Remove unused variable \"BarChart3\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Cpu' is defined but never used.","line":9,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":9,"endColumn":17,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"Cpu"},"fix":{"range":[355,360],"text":""},"desc":"Remove unused variable \"Cpu\"."}]},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/home/mohal665544/pr1/company-dashboard/app/super-admin/analytics/page.tsx:31:5\n  29 |\n  30 |   React.useEffect(() => {\n> 31 |     setMounted(true);\n     |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  32 |   }, []);\n  33 |\n  34 |   if (!hasCapability(\"view_analytics_snapshots\")) {","line":31,"column":5,"nodeType":null,"endLine":31,"endColumn":15}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// app/(super-admin)/analytics/page.tsx\n\"use client\";\n\nimport * as React from \"react\";\nimport { useAdminAuth } from \"@/features/platform-core/hooks/use-admin-auth\";\nimport { useAnalyticsSnapshotsQuery } from \"@/features/analytics/hooks/use-analytics-data\";\nimport { useAIInferenceLogsQuery } from \"@/features/ai/hooks/use-ai-config\";\nimport { \n  BarChart3, Cpu, AlertTriangle, TrendingUp, Clock, Activity\n} from \"lucide-react\";\nimport dynamic from \"next/dynamic\";\n\nconst AdminGrowthChart = dynamic(\n  () => import(\"@/features/super-admin/components/charts\").then((mod) => mod.AdminGrowthChart),\n  { ssr: false, loading: () => <div className=\"flex h-full items-center justify-center text-zinc-600 animate-pulse\">LOADING_GROWTH_CHART...</div> }\n);\n\nconst AdminLatencyChart = dynamic(\n  () => import(\"@/features/super-admin/components/charts\").then((mod) => mod.AdminLatencyChart),\n  { ssr: false, loading: () => <div className=\"flex h-full items-center justify-center text-zinc-600 animate-pulse\">LOADING_LATENCY_CHART...</div> }\n);\n\nexport default function AnalyticsPage() {\n  const { hasCapability } = useAdminAuth();\n  const { data: snapshots } = useAnalyticsSnapshotsQuery();\n  const { data: inferenceLogs } = useAIInferenceLogsQuery();\n\n  const [mounted, setMounted] = React.useState(false);\n\n  React.useEffect(() => {\n    setMounted(true);\n  }, []);\n\n  if (!hasCapability(\"view_analytics_snapshots\")) {\n    return (\n      <div className=\"flex h-[60vh] flex-col items-center justify-center border border-dashed border-red-500/40 bg-zinc-950 p-8 text-center font-mono text-xs\">\n        <AlertTriangle className=\"mb-4 h-8 w-8 text-red-500 animate-pulse\" />\n        <span className=\"text-red-500 font-bold uppercase tracking-wider\">ERROR: ACCESS_DENIED</span>\n        <p className=\"mt-2 text-zinc-400\">\n          Required Capability: <code className=\"bg-zinc-900 px-2 py-1 text-amber-500\">view_analytics_snapshots</code> is missing.\n        </p>\n      </div>\n    );\n  }\n\n  // Latency metrics calculation\n  const totalInferenceCount = inferenceLogs?.length || 0;\n  const averageLatency = totalInferenceCount > 0 \n    ? Math.round(inferenceLogs!.reduce((sum, item) => sum + item.latency_ms, 0) / totalInferenceCount)\n    : 0;\n\n  // Process data for charts\n  const historyData = snapshots?.map(snap => ({\n    date: snap.snapshot_date,\n    mrr: snap.total_mrr,\n    tenants: snap.total_tenants,\n    active: snap.active_tenants\n  })) || [];\n\n  const latencyTrendData = inferenceLogs?.slice(0, 15).reverse().map((log, idx) => ({\n    index: idx + 1,\n    latency: log.latency_ms,\n    tokens: log.tokens_used\n  })) || [];\n\n  // Cohort Retention Grid Mock Dataset (Industrial Matrix HUD)\n  const COHORT_RETENTION = [\n    { cohort: \"2025-Q1\", size: 24, m1: 100, m2: 95, m3: 91, m4: 87 },\n    { cohort: \"2025-Q2\", size: 30, m1: 100, m2: 96, m3: 90, m4: 83 },\n    { cohort: \"2025-Q3\", size: 18, m1: 100, m2: 94, m3: 88, m4: 82 },\n    { cohort: \"2025-Q4\", size: 22, m1: 100, m2: 98, m3: 95, m4: null },\n    { cohort: \"2026-Q1\", size: 28, m1: 100, m2: 96, m3: null, m4: null }\n  ];\n\n  return (\n    <div className=\"space-y-6 font-mono text-xs\">\n      {/* Title Header */}\n      <div className=\"flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between border border-zinc-800 bg-zinc-950 p-4\">\n        <div className=\"space-y-1\">\n          <h2 className=\"text-sm font-bold text-zinc-100 uppercase tracking-widest\">BUSINESS_INTELLIGENCE</h2>\n          <p className=\"text-[10px] text-zinc-500\">Global telemetry, cohort retention, and inference metrics</p>\n        </div>\n      </div>\n\n      {/* Summary KPI Cards */}\n      <div className=\"grid grid-cols-1 gap-4 sm:grid-cols-3\">\n        <div className=\"border border-zinc-800 bg-zinc-950 p-4\">\n          <div className=\"flex items-center justify-between text-zinc-500\">\n            <span className=\"text-[10px] font-bold uppercase\">NET_TENANT_GROWTH</span>\n            <TrendingUp className=\"h-4 w-4 text-emerald-500\" />\n          </div>\n          <div className=\"mt-2 flex items-baseline space-x-1\">\n            <span className=\"text-xl font-bold tracking-tight text-zinc-100\">\n              {snapshots ? snapshots[snapshots.length - 1]?.total_tenants - snapshots[0]?.total_tenants : 0}\n            </span>\n            <span className=\"text-[9px] text-zinc-500\">tenants overall growth</span>\n          </div>\n        </div>\n\n        <div className=\"border border-zinc-800 bg-zinc-950 p-4\">\n          <div className=\"flex items-center justify-between text-zinc-500\">\n            <span className=\"text-[10px] font-bold uppercase\">AVG_INFERENCE_LATENCY</span>\n            <Clock className=\"h-4 w-4 text-amber-500\" />\n          </div>\n          <div className=\"mt-2 flex items-baseline space-x-1\">\n            <span className=\"text-xl font-bold tracking-tight text-zinc-100\">{averageLatency}ms</span>\n            <span className=\"text-[9px] text-zinc-500\">active search endpoints</span>\n          </div>\n        </div>\n\n        <div className=\"border border-zinc-800 bg-zinc-950 p-4\">\n          <div className=\"flex items-center justify-between text-zinc-500\">\n            <span className=\"text-[10px] font-bold uppercase\">COHORT_LTV_ESTIMATE</span>\n            <Activity className=\"h-4 w-4 text-emerald-500\" />\n          </div>\n          <div className=\"mt-2 flex items-baseline space-x-1\">\n            <span className=\"text-xl font-bold tracking-tight text-zinc-100\">$8.4k</span>\n            <span className=\"text-[9px] text-emerald-500\">avg contract worth</span>\n          </div>\n        </div>\n      </div>\n\n      {/* Recharts Grid */}\n      <div className=\"grid grid-cols-1 gap-6 lg:grid-cols-2\">\n        {/* Tenant Scale Area Chart */}\n        <div className=\"border border-zinc-800 bg-zinc-950 p-4 space-y-4\">\n          <span className=\"block text-[10px] font-bold text-zinc-400 uppercase\">Tenant Account Growth Scale</span>\n          <div className=\"h-60 w-full\">\n            {mounted && historyData.length > 0 ? (\n              <AdminGrowthChart data={historyData} />\n            ) : (\n              <div className=\"flex h-full items-center justify-center text-zinc-600\">CHART_MOUNTING...</div>\n            )}\n          </div>\n        </div>\n\n        {/* AI Latency Trends */}\n        <div className=\"border border-zinc-800 bg-zinc-950 p-4 space-y-4\">\n          <span className=\"block text-[10px] font-bold text-zinc-400 uppercase\">Search Inference Latency Performance (ms)</span>\n          <div className=\"h-60 w-full\">\n            {mounted && latencyTrendData.length > 0 ? (\n              <AdminLatencyChart data={latencyTrendData} />\n            ) : (\n              <div className=\"flex h-full items-center justify-center text-zinc-600\">CHART_MOUNTING...</div>\n            )}\n          </div>\n        </div>\n      </div>\n\n      {/* Cohort Retention Matrix HUD */}\n      <div className=\"border border-zinc-800 bg-zinc-950 p-4\">\n        <div className=\"border-b border-zinc-800 pb-2 mb-3\">\n          <span className=\"font-bold text-[10px] text-zinc-400 uppercase\">COHORT_RETENTION_MATRIX</span>\n        </div>\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full text-center border-collapse\">\n            <thead>\n              <tr className=\"border-b border-zinc-800 text-zinc-500 uppercase text-[9px] bg-zinc-900/30\">\n                <th className=\"p-3 text-left font-bold\">Cohort</th>\n                <th className=\"p-3 font-bold\">Size</th>\n                <th className=\"p-3 font-bold\">Month 1</th>\n                <th className=\"p-3 font-bold\">Month 2</th>\n                <th className=\"p-3 font-bold\">Month 3</th>\n                <th className=\"p-3 font-bold\">Month 4</th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-zinc-850\">\n              {COHORT_RETENTION.map((item) => (\n                <tr key={item.cohort} className=\"hover:bg-zinc-900/40 transition-colors\">\n                  <td className=\"p-3 font-bold text-left text-zinc-300\">{item.cohort}</td>\n                  <td className=\"p-3 font-bold text-zinc-400\">{item.size} companies</td>\n                  \n                  {/* Month 1 */}\n                  <td className=\"p-3\">\n                    <span className=\"inline-block w-full bg-amber-500 text-black py-1 font-bold\">\n                      {item.m1}%\n                    </span>\n                  </td>\n\n                  {/* Month 2 */}\n                  <td className=\"p-3\">\n                    <span \n                      className=\"inline-block w-full py-1 font-bold text-zinc-100\"\n                      style={{ backgroundColor: `rgba(245, 158, 11, ${item.m2 ? item.m2 / 100 - 0.2 : 0})` }}\n                    >\n                      {item.m2}%\n                    </span>\n                  </td>\n\n                  {/* Month 3 */}\n                  <td className=\"p-3\">\n                    {item.m3 ? (\n                      <span \n                        className=\"inline-block w-full py-1 font-bold text-zinc-100\"\n                        style={{ backgroundColor: `rgba(245, 158, 11, ${item.m3 / 100 - 0.2})` }}\n                      >\n                        {item.m3}%\n                      </span>\n                    ) : (\n                      <span className=\"text-zinc-600 font-bold\">-</span>\n                    )}\n                  </td>\n\n                  {/* Month 4 */}\n                  <td className=\"p-3\">\n                    {item.m4 ? (\n                      <span \n                        className=\"inline-block w-full py-1 font-bold text-zinc-100\"\n                        style={{ backgroundColor: `rgba(245, 158, 11, ${item.m4 / 100 - 0.2})` }}\n                      >\n                        {item.m4}%\n                      </span>\n                    ) : (\n                      <span className=\"text-zinc-600 font-bold\">-</span>\n                    )}\n                  </td>\n                </tr>\n              ))}\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/mohal665544/pr1/company-dashboard/app/super-admin/audit/page.tsx","messages":[{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/platform-core/hooks/use-admin-auth' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":5,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":5,"endColumn":78},{"ruleId":"no-restricted-imports","severity":2,"message":"'@/features/platform-core/hooks/use-audit-logs' import is restricted from being used by a pattern. Please do not import internal feature files. Only import from the feature's index file.","line":6,"column":1,"nodeType":"ImportDeclaration","messageId":"patternWithCustomMessage","endLine":6,"endColumn":83},{"ruleId":"@typescript-